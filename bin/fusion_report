#!/usr/bin/env python3
"""Fusion Report CLI Entry Point.

Command-line interface for the Fusion Report application. Parses command-line
arguments and executes the requested command (run, download, or createdb).

Raises:
    AppException: For application-level errors during execution.
    SystemExit: With non-zero exit code on AppException.
"""
import sys

from fusion_report.app import App
from fusion_report.common.exceptions.app import AppException
from fusion_report.common.logger import Logger

if __name__ == "__main__":
    try:
        app = App()
        app.build_args()
        app.run()
    except AppException as ex:
        Logger(__name__).fatal(ex, exc_info=True)
        sys.exit(ex.args[0])
